{
  "name": "qubicshield-demo",
  "version": "0.1.0",
  "description": "QubicShield – DDoS protection via refundable QUBIC deposits (MVP demo)",
  "main": "dist/server.js",
  "scripts": {
    "start": "ts-node src/server.ts",
    "build": "tsc && npm run build:browser",
    "build:browser": "esbuild src/browser/qsign.ts --bundle --platform=browser --target=es2020 --outfile=public/qsign.js --global-name=QSign",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "test": "ts-node src/test/run.ts",
    "demo": "ts-node src/demo-client.ts"
  },
  "dependencies": {
    "@qubic-lib/qubic-ts-library": "^0.1.6",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.7",
    "esbuild": "^0.20.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
